@page "/clients"
@inject HttpClient Http

<div class="page-header">
    <h2>👥 Clients</h2>
    <button class="btn-primary" @onclick="() => { showForm = true; editingClient = null; resetForm(); }">+ New Client</button>
</div>

@if (showForm)
{
    <div class="form-card">
        <h3>@(editingClient == null ? "New Client" : "Edit Client")</h3>

        <label>Full Name *</label>
        <input @bind="formName" placeholder="e.g. John Smith"/>

        <label>Phone</label>
        <input @bind="formPhone" placeholder="e.g. 0412 345 678"/>

        <label>Email</label>
        <input @bind="formEmail" placeholder="e.g. john@email.com"/>

        <label>Address</label>
        <textarea @bind="formAddress" placeholder="e.g. 12 Main St, Perth WA 6000"></textarea>

        <button class="btn-primary" @onclick="SaveClient">
            @(editingClient == null ? "+ Add Client" : "💾 Save Changes")
        </button>
        <button class="btn-secondary" @onclick="() => showForm = false">Cancel</button>
    </div>
}

@foreach (var client in clients)
{
    <div class="client-card">
        <div>
            <h3>@client.Name</h3>
            <p>📞 @client.Phone</p>
            <p>✉️ @client.Email</p>
            <p>📍 @client.Address</p>
        </div>
        <div style="display:flex; gap:8px; flex-direction:column; align-items:flex-end;">
            <button class="btn-primary" @onclick="() => StartEdit(client)">✏️ Edit</button>
            <button class="btn-red" @onclick="() => DeleteClient(client.Id)">🗑 Delete</button>
        </div>
    </div>
}

@if (!clients.Any())
{
    <div class="empty">No clients yet. Add your first client!</div>
}

@code {
    private List<TradieMateWeb.Client.Models.Client> clients = new();
    private TradieMateWeb.Client.Models.Client? editingClient = null;
    private bool showForm = false;

    private string formName = string.Empty;
    private string formPhone = string.Empty;
    private string formEmail = string.Empty;
    private string formAddress = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadClients();
    }

    private async Task LoadClients()
    {
        try
        {
            clients = await Http.GetFromJsonAsync<List<TradieMateWeb.Client.Models.Client>>("Clients") ?? new();
        }
        catch { }
    }

    private void resetForm()
    {
        formName = string.Empty;
        formPhone = string.Empty;
        formEmail = string.Empty;
        formAddress = string.Empty;
    }

    private void StartEdit(TradieMateWeb.Client.Models.Client client)
    {
        editingClient = client;
        formName = client.Name;
        formPhone = client.Phone;
        formEmail = client.Email;
        formAddress = client.Address;
        showForm = true;
    }

    private async Task SaveClient()
    {
        if (string.IsNullOrWhiteSpace(formName)) return;

        if (editingClient == null)
        {
            var newClient = new TradieMateWeb.Client.Models.Client
            {
                Name = formName,
                Phone = formPhone,
                Email = formEmail,
                Address = formAddress
            };
            await Http.PostAsJsonAsync("Clients", newClient);
        }
        else
        {
            editingClient.Name = formName;
            editingClient.Phone = formPhone;
            editingClient.Email = formEmail;
            editingClient.Address = formAddress;
            await Http.PutAsJsonAsync($"Clients/{editingClient.Id}", editingClient);
        }

        showForm = false;
        editingClient = null;
        resetForm();
        await LoadClients();
    }

    private async Task DeleteClient(int id)
    {
        await Http.DeleteAsync($"Clients/{id}");
        await LoadClients();
    }
}