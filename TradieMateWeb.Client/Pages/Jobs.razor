@page "/jobs"
@inject HttpClient Http
@inject NavigationManager Nav
@inject IJSRuntime JS
@using TradieMateWeb.Client.Models

<div class="page-header">
    <h2>📋 Jobs</h2>
    <button class="btn-primary" @onclick="() => { showForm = true; editingJob = null; resetForm(); }">+ New Job</button>
</div>

@if (showForm)
{
    <div class="form-card">
        <h3>@(editingJob == null ? "New Job" : "Edit Job")</h3>

        <label>Client</label>
        <select @bind="formClientId">
            <option value="0">-- Select Client --</option>
            @foreach (var c in clients)
            {
                <option value="@c.Id">@c.Name</option>
            }
        </select>

        <label>Job Title</label>
        <input @bind="formTitle" placeholder="e.g. Fix leaking pipe"/>

        <label>Description</label>
        <textarea @bind="formDescription" placeholder="Job details..."></textarea>

        <label>Status</label>
        <select @bind="formStatus">
            <option>Pending</option>
            <option>In Progress</option>
            <option>Completed</option>
        </select>

        <label>Due Date</label>
        <input type="date" @bind="formDueDate"/>

        <label>Payment Terms</label>
        <input @bind="formPaymentTerms" placeholder="e.g. Net 14"/>

        <!-- Line Items -->
        <div style="margin-top:16px;">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:8px;">
                <label style="margin:0; font-size:14px; font-weight:bold; color:#89b4fa;">Invoice Items</label>
                <button class="btn-primary" type="button" @onclick="AddLineItem">+ Add Item</button>
            </div>

            @if (formItems.Any())
            {
                <div style="background:#45475a; border-radius:8px; padding:12px; margin-bottom:8px;">
                    <div style="display:grid; grid-template-columns:2fr 1fr 1fr 1fr auto; gap:8px; margin-bottom:8px;">
                        <span style="font-size:11px; color:#cdd6f4;">Description</span>
                        <span style="font-size:11px; color:#cdd6f4;">Qty</span>
                        <span style="font-size:11px; color:#cdd6f4;">Unit Price</span>
                        <span style="font-size:11px; color:#cdd6f4;">Amount</span>
                        <span></span>
                    </div>
                    @foreach (var item in formItems)
                    {
                        <div style="display:grid; grid-template-columns:2fr 1fr 1fr 1fr auto; gap:8px; margin-bottom:8px; align-items:center;">
                            <input @bind="item.Description" placeholder="e.g. Labour"/>
                            <input type="number" @bind="item.Quantity" placeholder="1"/>
                            <input type="number" @bind="item.UnitPrice" placeholder="0.00"/>
                            <span style="color:#a6e3a1; font-size:13px;">$@item.Amount.ToString("N2")</span>
                            <button class="btn-red" style="padding:4px 8px;" @onclick="() => RemoveLineItem(item)">✕</button>
                        </div>
                    }
                </div>

                <div style="text-align:right; padding:8px; background:#313244; border-radius:6px;">
                    <span style="color:#6c7086; font-size:13px;">Total: </span>
                    <span style="color:white; font-weight:bold;">$@formItems.Sum(i => i.Amount).ToString("N2")</span>
                </div>
            }
            else
            {
                <div style="text-align:center; color:#6c7086; padding:16px; background:#313244; border-radius:8px;">
                    No items yet. Click "+ Add Item" to start.
                </div>
            }
        </div>

        <button class="btn-primary" @onclick="SaveJob">
            @(editingJob == null ? "+ Add Job" : "💾 Save Changes")
        </button>
        <button class="btn-secondary" @onclick="() => showForm = false">Cancel</button>
    </div>
}

<!-- Summary -->
<div class="cards">
    <div class="card green">
        <p>Total Earned</p>
        <h2>$@jobs.Where(j => j.IsPaid).Sum(j => j.TotalAmount).ToString("N0")</h2>
    </div>
    <div class="card red">
        <p>Unpaid</p>
        <h2>$@jobs.Where(j => !j.IsPaid).Sum(j => j.TotalAmount).ToString("N0")</h2>
    </div>
</div>

<!-- Jobs List -->
@foreach (var job in jobs)
{
    <div class="job-card">
        <div class="job-info">
            <h3>@job.Title</h3>
            <p class="client-name">👤 @(job.Client?.Name ?? "Unknown")</p>
            <p>@job.Description</p>
            <span class="badge @job.Status.Replace(" ", "")">@job.Status</span>
            <span class="badge @(job.IsPaid ? "Paid" : "Unpaid")">
                @(job.IsPaid ? "✅ Paid" : "⏳ Unpaid")
            </span>
            @if (job.InvoiceItems.Any())
            {
                <p style="font-size:12px; color:#6c7086; margin-top:4px;">
                    @job.InvoiceItems.Count item(s)
                </p>
            }
        </div>
        <div class="job-amount">
            <h3>$@job.TotalAmount.ToString("N0")</h3>
            <p>Due: @job.DueDate.ToString("dd MMM yyyy")</p>
            <p>Terms: @job.PaymentTerms</p>
            <div class="job-actions">
                <button class="btn-primary" @onclick="() => StartEdit(job)">✏️ Edit</button>
                @if (!job.IsPaid)
                {
                    <button class="btn-green" @onclick="() => MarkAsPaid(job.Id)">✅ Paid</button>
                }
                <button class="btn-purple" @onclick="() => GenerateAndShareInvoice(job.Id)">📄 Invoice</button>
                <button class="btn-blue-share" @onclick="() => ShareInvoice(job.Id, job.Client?.Name ?? string.Empty)">📤 Share</button>
                <button class="btn-red" @onclick="() => DeleteJob(job.Id)">🗑 Delete</button>
            </div>
        </div>
    </div>
}

@if (!jobs.Any())
{
    <div class="empty">No jobs yet. Add your first job!</div>
}

@code {
    private List<Job> jobs = new();
    private List<Client> clients = new();
    private Job? editingJob = null;
    private bool showForm = false;

    private int formClientId = 0;
    private string formTitle = string.Empty;
    private string formDescription = string.Empty;
    private string formStatus = "Pending";
    private DateTime formDueDate = DateTime.Now.AddDays(14);
    private string formPaymentTerms = "Net 14";
    private List<InvoiceItem> formItems = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            jobs = await Http.GetFromJsonAsync<List<Job>>("Jobs") ?? new();
            clients = await Http.GetFromJsonAsync<List<Client>>("Clients") ?? new();
        }
        catch { }
    }

    private void resetForm()
    {
        formClientId = 0;
        formTitle = string.Empty;
        formDescription = string.Empty;
        formStatus = "Pending";
        formDueDate = DateTime.Now.AddDays(14);
        formPaymentTerms = "Net 14";
        formItems = new();
    }

    private void StartEdit(Job job)
    {
        editingJob = job;
        formClientId = job.ClientId;
        formTitle = job.Title;
        formDescription = job.Description;
        formStatus = job.Status;
        formDueDate = job.DueDate;
        formPaymentTerms = job.PaymentTerms;
        formItems = job.InvoiceItems.Select(i => new InvoiceItem
        {
            Id = i.Id,
            JobId = i.JobId,
            Description = i.Description,
            Quantity = i.Quantity,
            UnitPrice = i.UnitPrice
        }).ToList();
        showForm = true;
    }

    private async Task SaveJob()
    {
        if (string.IsNullOrWhiteSpace(formTitle) || formClientId == 0) return;

        if (editingJob == null)
        {
            var newJob = new Job
            {
                ClientId = formClientId,
                Title = formTitle,
                Description = formDescription,
                Status = formStatus,
                DueDate = formDueDate.ToUniversalTime(),
                JobDate = DateTime.UtcNow,
                PaymentTerms = formPaymentTerms,
                InvoiceItems = formItems
            };
            await Http.PostAsJsonAsync("Jobs", newJob);
        }
        else
        {
            editingJob.ClientId = formClientId;
            editingJob.Title = formTitle;
            editingJob.Description = formDescription;
            editingJob.Status = formStatus;
            editingJob.DueDate = formDueDate;
            editingJob.PaymentTerms = formPaymentTerms;
            editingJob.InvoiceItems = formItems;
            await Http.PutAsJsonAsync($"Jobs/{editingJob.Id}", editingJob);
        }

        showForm = false;
        editingJob = null;
        resetForm();
        await LoadData();
    }

    private async Task MarkAsPaid(int id)
    {
        await Http.PutAsJsonAsync($"Jobs/{id}/pay", new { });
        await LoadData();
    }

    private async Task DeleteJob(int id)
    {
        await Http.DeleteAsync($"Jobs/{id}");
        await LoadData();
    }

    private void AddLineItem()
    {
        formItems.Add(new InvoiceItem { Quantity = 1 });
    }

    private void RemoveLineItem(InvoiceItem item)
    {
        formItems.Remove(item);
    }

    private async Task GenerateAndShareInvoice(int jobId)
    {
        try
        {
            var response = await Http.GetAsync($"Jobs/{jobId}/invoice");
            if (!response.IsSuccessStatusCode) return;

            var pdfBytes = await response.Content.ReadAsByteArrayAsync();
            var base64 = Convert.ToBase64String(pdfBytes);
            await JS.InvokeVoidAsync("downloadPdf", base64, $"Invoice_{jobId:D4}.pdf");
        }
        catch { }
    }

    private async Task ShareInvoice(int jobId, string clientName)
    {
        try
        {
            var response = await Http.GetAsync($"Jobs/{jobId}/invoice");
            if (!response.IsSuccessStatusCode) return;

            var pdfBytes = await response.Content.ReadAsByteArrayAsync();
            var base64 = Convert.ToBase64String(pdfBytes);
            await JS.InvokeVoidAsync("shareInvoice", base64,
                $"Invoice_{jobId:D4}.pdf",
                $"Invoice #{jobId:D4} from TradieMate",
                $"Please find attached invoice #{jobId:D4}. Thank you for your business!");
        }
        catch { }
    }
}