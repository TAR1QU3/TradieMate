@page "/jobs"
@inject HttpClient Http
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="page-header">
    <h2>📋 Jobs</h2>
    <button class="btn-primary" @onclick="() => { showForm = true; editingJob = null; resetForm(); }">+ New Job</button>
</div>

@if (showForm)
{
    <div class="form-card">
        <h3>@(editingJob == null ? "New Job" : "Edit Job")</h3>

        <label>Client</label>
        <select @bind="formClientId">
            <option value="0">-- Select Client --</option>
            @foreach (var c in clients)
            {
                <option value="@c.Id">@c.Name</option>
            }
        </select>

        <label>Job Title</label>
        <input @bind="formTitle" placeholder="e.g. Fix leaking pipe"/>

        <label>Description</label>
        <textarea @bind="formDescription" placeholder="Job details..."></textarea>

        <label>Total Amount ($)</label>
        <input type="number" @bind="formLaborCost"/>

        <label>Status</label>
        <select @bind="formStatus">
            <option>Pending</option>
            <option>In Progress</option>
            <option>Completed</option>
        </select>

        <label>Due Date</label>
        <input type="date" @bind="formDueDate"/>

        <label>Payment Terms</label>
        <input @bind="formPaymentTerms" placeholder="e.g. Net 14"/>

        <button class="btn-primary" @onclick="SaveJob">
            @(editingJob == null ? "+ Add Job" : "💾 Save Changes")
        </button>
        <button class="btn-secondary" @onclick="() => showForm = false">Cancel</button>
    </div>
}

<!-- Summary -->
<div class="cards">
    <div class="card green">
        <p>Total Earned</p>
        <h2>$@jobs.Where(j => j.IsPaid).Sum(j => j.TotalAmount).ToString("N0")</h2>
    </div>
    <div class="card red">
        <p>Unpaid</p>
        <h2>$@jobs.Where(j => !j.IsPaid).Sum(j => j.TotalAmount).ToString("N0")</h2>
    </div>
</div>

<!-- Jobs List -->
@foreach (var job in jobs)
{
    <div class="job-card">

        <!-- LEFT SIDE -->
        <div class="job-info">
            <h3>@job.Title</h3>
            <p class="client-name">👤 @(job.Client?.Name ?? "Unknown")</p>
            <p>@job.Description</p>

            <span class="badge @job.Status.Replace(" ", "")">@job.Status</span>
            <span class="badge @(job.IsPaid ? "Paid" : "Unpaid")">
                @(job.IsPaid ? "✅ Paid" : "⏳ Unpaid")
            </span>
        </div>

        <!-- RIGHT SIDE (PRO INVOICE VIEW) -->
        <div class="job-amount">

            <div class="invoice-preview">

                <div class="invoice-header">
                    <h4>INVOICE</h4>
                    <span>#@job.Id.ToString("D4")</span>
                </div>

                <div class="invoice-meta">
                    <div>
                        <strong>Client</strong><br />
                        @job.Client?.Name
                    </div>
                    <div>
                        <strong>Due</strong><br />
                        @job.DueDate.ToString("dd MMM yyyy")
                    </div>
                </div>

                <table class="invoice-table">
                    <thead>
                        <tr>
                            <th>Description</th>
                            <th style="width:120px;">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>@job.Title</td>
                            <td>$@job.TotalAmount.ToString("N2")</td>
                        </tr>
                    </tbody>
                </table>

                <div class="invoice-total">
                    <div>
                        <span>Subtotal</span>
                        <span>$@job.TotalAmount.ToString("N2")</span>
                    </div>

                    <div>
                        <span>GST (10%)</span>
                        <span>$@((job.TotalAmount * 0.1).ToString("N2"))</span>
                    </div>

                    <div class="grand-total">
                        <strong>Total</strong>
                        <strong>$@((job.TotalAmount * 1.1).ToString("N2"))</strong>
                    </div>
                </div>

            </div>

            <div class="job-actions">
                <button class="btn-primary" @onclick="() => StartEdit(job)">✏️ Edit</button>

                @if (!job.IsPaid)
                {
                    <button class="btn-green" @onclick="() => MarkAsPaid(job.Id)">✅ Paid</button>
                }

                <button class="btn-purple" @onclick="() => GenerateAndShareInvoice(job.Id)">📄 PDF</button>
                <button class="btn-blue-share" @onclick="() => ShareInvoice(job.Id, job.Client?.Name ?? string.Empty)">📤 Share</button>
                <button class="btn-red" @onclick="() => DeleteJob(job.Id)">🗑 Delete</button>
            </div>

        </div>
    </div>
}

@if (!jobs.Any())
{
    <div class="empty">No jobs yet. Add your first job!</div>
}

@code {
    private List<TradieMateWeb.Client.Models.Job> jobs = new();
    private List<TradieMateWeb.Client.Models.Client> clients = new();
    private TradieMateWeb.Client.Models.Job? editingJob = null;
    private bool showForm = false;

    private int formClientId = 0;
    private string formTitle = string.Empty;
    private string formDescription = string.Empty;
    private double formLaborCost = 0;
    private string formStatus = "Pending";
    private DateTime formDueDate = DateTime.Now.AddDays(14);
    private string formPaymentTerms = "Net 14";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        jobs = await Http.GetFromJsonAsync<List<TradieMateWeb.Client.Models.Job>>("Jobs") ?? new();
        clients = await Http.GetFromJsonAsync<List<TradieMateWeb.Client.Models.Client>>("Clients") ?? new();
    }

    private void resetForm()
    {
        formClientId = 0;
        formTitle = "";
        formDescription = "";
        formLaborCost = 0;
        formStatus = "Pending";
        formDueDate = DateTime.Now.AddDays(14);
        formPaymentTerms = "Net 14";
    }

    private void StartEdit(TradieMateWeb.Client.Models.Job job)
    {
        editingJob = job;
        formClientId = job.ClientId;
        formTitle = job.Title;
        formDescription = job.Description;
        formLaborCost = job.TotalAmount;
        formStatus = job.Status;
        formDueDate = job.DueDate;
        formPaymentTerms = job.PaymentTerms;
        showForm = true;
    }

    private async Task SaveJob()
    {
        if (string.IsNullOrWhiteSpace(formTitle) || formClientId == 0) return;

        var job = new TradieMateWeb.Client.Models.Job
        {
            ClientId = formClientId,
            Title = formTitle,
            Description = formDescription,
            LaborCost = formLaborCost,
            MaterialCost = 0,
            Status = formStatus,
            DueDate = formDueDate,
            PaymentTerms = formPaymentTerms
        };

        if (editingJob == null)
            await Http.PostAsJsonAsync("Jobs", job);
        else
            await Http.PutAsJsonAsync($"Jobs/{editingJob.Id}", job);

        showForm = false;
        editingJob = null;
        await LoadData();
    }

    private async Task MarkAsPaid(int id)
    {
        await Http.PutAsJsonAsync($"Jobs/{id}/pay", new { });
        await LoadData();
    }

    private async Task DeleteJob(int id)
    {
        await Http.DeleteAsync($"Jobs/{id}");
        await LoadData();
    }

    private async Task GenerateAndShareInvoice(int jobId)
    {
        var response = await Http.GetAsync($"Jobs/{jobId}/invoice");
        if (!response.IsSuccessStatusCode) return;

        var pdfBytes = await response.Content.ReadAsByteArrayAsync();
        var base64 = Convert.ToBase64String(pdfBytes);
        await JS.InvokeVoidAsync("downloadPdf", base64, $"Invoice_{jobId:D4}.pdf");
    }

    private async Task ShareInvoice(int jobId, string clientName)
    {
        var response = await Http.GetAsync($"Jobs/{jobId}/invoice");
        if (!response.IsSuccessStatusCode) return;

        var pdfBytes = await response.Content.ReadAsByteArrayAsync();
        var base64 = Convert.ToBase64String(pdfBytes);

        await JS.InvokeVoidAsync("shareInvoice", base64,
            $"Invoice_{jobId:D4}.pdf",
            $"Invoice #{jobId:D4}",
            $"Please find attached invoice.");
    }
}